{
  "openapi": "3.0.0",
  "info": {
    "version": "1.0.0",
    "title": "User API",
    "description": "An API for testing form field defaults"
  },
  "servers": [
    {
      "url": "http://user-api.example.com"
    }
  ],
  "paths": {
    "/users": {
      "post": {
        "summary": "Create a user",
        "operationId": "createUser",
        "requestBody": {
          "required": true,
          "content": {
            "application/x-www-form-urlencoded": {
              "schema": {
                "$ref": "#/components/schemas/User"
              }
            }
          }
        },
        "responses": {
          "201": {
            "description": "User created"
          }
        }
      }
    }
  },
  "components": {
    "schemas": {
      "User": {
        "type": "object",
        "properties": {
          "name": {
            "type": "string",
            "example": "Jane Doe"
          },
          "age": {
            "type": "integer",
            "default": 30
          },
          "email": {
            "type": "string"
          },
          "score": {
            "type": "number"
          },
          "active": {
            "type": "boolean"
          }
        }
      }
    }
  }
}
