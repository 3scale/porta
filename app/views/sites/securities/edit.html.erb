<% content_for :title, 'Security' %>
<% content_for :page_header_title, 'Security' %>
<% content_for :page_header_body do %>
  <p>Configure security headers for the developer portal.</p>
  <p>The Permissions-Policy header controls which browser features can be used in the developer portal.</p>
<% end %>

<%= semantic_form_for @permission_policy_dev_portal, 
                      as: :account_setting,
                      url: admin_site_security_path, 
                      method: :put,
                      html: { class: 'formtastic' } do |f| %>
  <%= f.inputs do %>
    <%= f.input :value, 
                label: 'Permissions-Policy Header',
                hint: 'Format: directive1=(), directive2=(self). Example: camera=(), microphone=(), geolocation=(). Leave empty for no restrictions.',
                input_html: { placeholder: 'Leave empty for permissive policy (no restrictions)' } %>
  <% end %>

  <%= f.actions do %>
    <%= f.action :submit, label: 'Update Security Settings', button_html: { class: 'btn btn-primary' } %>
  <% end %>
<% end %>

<div class="well">
  <h4>Available Directives</h4>
  <p>Common directives you can use:</p>
  <ul>
    <li><code>camera</code> - Camera access</li>
    <li><code>microphone</code> - Microphone access</li>
    <li><code>geolocation</code> - Geolocation access</li>
    <li><code>usb</code> - USB device access</li>
    <li><code>payment</code> - Payment Request API</li>
    <li><code>fullscreen</code> - Fullscreen mode</li>
    <li><code>autoplay</code> - Autoplay media</li>
  </ul>
  <p>Values: <code>()</code> = none, <code>(self)</code> = same origin only, <code>(*)</code> = all origins</p>
  <p><strong>Note:</strong> Developer portal is permissive by default (empty = no restrictions). Only add restrictions if needed for your use case.</p>
</div>
