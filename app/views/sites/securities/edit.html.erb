<% content_for :title, 'Security' %>
<% content_for :page_header_title, 'Security' %>
<% content_for :page_header_body do %>
  <p><%= t('.description') %></p>
  <p>Configure security settings for the developer portal, including spam protection and browser feature permissions.</p>
<% end %>

<%= render partial: 'provider/admin/securities/form', locals: { url: admin_site_security_path, settings: @settings, field: :spam_protection_level, selector_label: t('.selector_label') } %>

<div class="well">
  <h3>Permissions-Policy Header</h3>
  
  <%= semantic_form_for @permission_policy_developer_portal, 
                        as: :account_setting,
                        url: admin_site_security_path, 
                        method: :put,
                        html: { class: 'formtastic' } do |f| %>
    <%= f.inputs do %>
      <%= f.input :value, 
                  label: 'Permissions-Policy Header',
                  hint: 'Format: directive1=(), directive2=(self). Example: camera=(), microphone=(), geolocation=(). Leave empty for no restrictions.',
                  input_html: { placeholder: AccountSetting::PermissionsPolicyHeaderDeveloper.default_value } %>
    <% end %>

    <%= f.actions do %>
      <%= f.action :submit, label: 'Update Permissions Policy', button_html: { class: 'btn btn-primary' } %>
    <% end %>
  <% end %>
</div>

<div class="well">
  <h4>Available Directives</h4>
  <p>Common directives you can use:</p>
  <ul>
    <li><code>camera</code> - Camera access</li>
    <li><code>microphone</code> - Microphone access</li>
    <li><code>geolocation</code> - Geolocation access</li>
    <li><code>usb</code> - USB device access</li>
    <li><code>payment</code> - Payment Request API</li>
    <li><code>fullscreen</code> - Fullscreen mode</li>
  </ul>
  <p>Values: <code>()</code> = none, <code>(self)</code> = same origin only</p>
  <p>Default (empty) = no restrictions, allowing all features</p>
</div>